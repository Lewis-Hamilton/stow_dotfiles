# default_floating_border pixel 1

for_window [class="URxvt"] border pixel 1
client.focused #ffffff #ffffff #ffffff #ffffff #ffffff 

# Set a persistent wallpaper using feh
exec_always --no-startup-id feh --bg-fill /usr/share/backgrounds/speed.png

# Start Keyring daemon for 1Password
