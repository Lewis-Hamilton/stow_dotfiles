	name = Lewis

[core]
    editor = vim

[fetch]
	prune = true

[alias]
    trash = !git branch --merged | grep -v \"^\\*\\| main$\\| master$\" | xargs -r -n1 git branch -d

[includeIf "hasconfig:remote.*.url:git@github.com:acretrader/**"]
	path = ~/.gitconfig-work