# Sourced by Fedora's /etc/X11/xinit/xinitrc-common at X session startup
# (before i3), and by login shells. Unlike ~/.xprofile (a Debian/Ubuntu
# convention that Fedora ignores), this file IS sourced on Fedora.
#
# Force a dark GTK theme so GTK + Electron apps (e.g. 1Password) render dark.
export GTK_THEME=Adwaita:dark
