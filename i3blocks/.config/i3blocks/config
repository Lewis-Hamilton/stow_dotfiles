# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$SCRIPT_DIR/$BLOCK_NAME
separator_block_width=15
markup=none

# Date Time
#
[time]
command=date '+%I:%M %p %m/%d/%Y'
interval=10
min_width=850
align=center
separator=false

[notifications]
command=$SCRIPT_DIR/notifications/notifications
interval=30
signal=12
markup=pango

[uptime]
command=$SCRIPT_DIR/uptime/uptime
interval=600
markup=pango

[flatpak_updates]
command=$SCRIPT_DIR/flatpak-updates/flatpak-updates
interval=600
markup=pango

[updates]
command=$SCRIPT_DIR/dnf-updates/dnf-updates
#label=Updates
interval=600
markup=pango

# Volume indicator
#
# The first parameter sets the step (and units to display)
# The second parameter overrides the mixer selection
# See the script for details.

[volume]
command=$SCRIPT_DIR/volume/volume
interval=once
signal=10
markup=pango
#STEP=5%

[brightness]
command=$SCRIPT_DIR/brightness/brightness
interval=once
signal=9
markup=pango

# Memory usage
#
# The type defaults to "mem" if the instance is not specified.
[memory]
command=$SCRIPT_DIR/memory/memory
# separator=false
interval=15
markup=pango

# Network interface monitoring
#
# If the instance is not specified, use the interface used for default route.
# The address can be forced to IPv4 or IPv6 with -4 or -6 switches.
[iface]
#IFACE=wlan0
color=#00FF00
interval=10
separator=false

[wifi]
#INTERFACE=wlp3s0
label=wifi:
interval=10
separator=false

[bandwidth]
#INTERFACE=eth0
interval=5

# CPU usage
#
# The script may be called with -w and -c switches to specify thresholds,
# see the script for details.
#separator=false

[fan_speed]
command=$SCRIPT_DIR/fan_speed/fan_speed
interval=15
markup=pango

[cpu]
command=$SCRIPT_DIR/cpu/cpu
interval=15
markup=pango

[load_average]
label=LOAD
interval=10

# Battery indicator
#
# The battery instance defaults to 0.
[battery]
command=$SCRIPT_DIR/battery/battery
interval=30

# Generic media player support
#
# This displays "ARTIST - SONG" if a music is playing.
# Supported players are: spotify, vlc, audacious, xmms2, mplayer, and others.
# Set to %any to automatically pick (Requires playerctl >=2.1.1)
#[mediaplayer]
# This picks any player, with vlc as first, and spotify as last choice
#instance=vlc,%any,spotify
#interval=5
#signal=10

# OpenVPN support
#
# Support multiple VPN, with colors.
#[openvpn]
#interval=20

