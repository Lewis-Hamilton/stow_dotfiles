#!/bin/bash

source ~/.my_colors.sh

# This script gets the number of available DNF updates
updates=$(dnf check-update -q | wc -l)

if [ "$updates" -eq 0 ]; then
	color=$MY_GREEN
elif [[ "$updates" -gt 0 && "$updates" -le 5 ]]; then
	color=$MY_YELLOW
elif [[ "$updates" -gt 5 && "$updates" -le 10 ]]; then
	color=$MY_ORANGE
elif [[ "$updates" -gt 10 && "$updates" -le 99 ]]; then
	color=$MY_RED
elif [ "$updates" -gt 99 ]; then
	updates="底롲펿"
	color=$MY_RED
else
	updates="ER"
	color=$MY_RED
fi

printf -v padded_output "%2s" "$updates"


echo "<span color=\"$color\">$padded_output </span><span color=\"$color\" size='large'>箚슦</span>"
