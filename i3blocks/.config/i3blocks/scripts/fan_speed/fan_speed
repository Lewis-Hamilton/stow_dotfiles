#!/bin/bash

source ~/.my_colors.sh

# 1. Capture raw sensors data once
sensors_raw=$(sensors)

# 2. Extract the correct fan line depending on the machine
if echo "$sensors_raw" | grep -q "fan2:"; then
    # Desktop: Target the true CPU fan header directly
    fan_line=$(echo "$sensors_raw" | grep "fan2:")
else
    # Laptop: Grab the first spinning fan line available
    fan_line=$(echo "$sensors_raw" | grep -i "fan" | grep -v "0 RPM" | head -n 1)
fi

# 3. Safely parse out just the numerical RPM value
if [[ -n "$fan_line" ]]; then
    clean_line=$(echo "$fan_line" | awk -F: '{print $2}')
    fan_speed=$(echo "$clean_line" | grep -oE '[0-9]+' | head -n 1)
else
    fan_speed=0
fi

if [ "$fan_speed" -le 800 ]; then
    color=$MY_GREEN
elif [[ "$fan_speed" -gt 800 && "$fan_speed" -le 1600 ]]; then
    color=$MY_YELLOW
elif [[ "$fan_speed" -gt 1600 && "$fan_speed" -le 2400 ]]; then
    color=$MY_ORANGE
else
    color=$MY_RED
fi

echo "<span color=\"$color\">$fan_speed </span><span color=\"$color\" size='large'>󰈐</span>"