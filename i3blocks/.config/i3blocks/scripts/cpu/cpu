#!/bin/bash

source ~/.my_colors.sh

# CPU Usage
CPU_USAGE=$(top -bn1 | grep "Cpu(s)" | awk '{printf "%.0f", 100 - $8}')
OUTPUT_VALUE=${CPU_USAGE}%

if [ "$CPU_USAGE" -le 50 ]; then
        usage_color=$MY_GREEN
elif [[ "$CPU_USAGE" -gt 50 && "$CPU_USAGE" -le 70 ]]; then
        usage_color=$MY_YELLOW
elif [[ "$CPU_USAGE" -gt 70 && "$CPU_USAGE" -le 85 ]]; then
        usage_color=$MY_ORANGE
elif [[ "$CPU_USAGE" -gt 85 && "$CPU_USAGE" -le 99 ]]; then
        usage_color=$MY_RED
elif [ "$CPU_USAGE" -gt 99 ]; then
        OUTPUT_VALUE="îĽŽîĽŽîĽŽ"
else
        OUTPUT_VALUE="ERR"
        usage_color=$MY_RED
fi

# CPU Temperature

# 1. Capture raw sensors data once
sensors_raw=$(sensors)

# 2. Extract the single best temperature line based on machine
if echo "$sensors_raw" | grep -q "PECI Agent 0"; then
    target_line=$(echo "$sensors_raw" | grep "PECI Agent 0" | head -n 1)
else
    target_line=$(echo "$sensors_raw" | grep 'CPU:' | head -n 1)
fi

# 3. Apply your exact extraction and rounding logic
temperature=$(echo "$target_line" | awk -F '[+Â°]' '{print $2}')
formatted_temperature=$(echo "$temperature" | awk '{printf "%.0f", $1}')

# Fallback check if both grep attempts somehow failed
if [[ -z "$formatted_temperature" ]]; then
    formatted_temperature="error"
fi

if [ "$formatted_temperature" -le 50 ]; then
        temp_color=$MY_GREEN
elif [[ "$formatted_temperature" -gt 50 && "$formatted_temperature" -le 60 ]]; then
        temp_color=$MY_YELLOW
elif [[ "$formatted_temperature" -gt 60 && "$formatted_temperature" -le 70 ]]; then
        temp_color=$MY_ORANGE
else
        temp_color=$MY_RED
fi

printf -v padded_usage "%3s" "$OUTPUT_VALUE"

echo "<span color=\"$usage_color\" size='large'>ó°“…</span><span color=\"$usage_color\"> $padded_usage</span><span size='large'> ó°ź€ </span><span color=\"$temp_color\">$formatted_temperatureÂ°C </span><span color=\"$temp_color\" size='large'>ď‹‰</span>"